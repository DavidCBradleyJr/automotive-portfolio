# Cloudinary credentials (required for build and migration)
# Get these from: https://console.cloudinary.com/settings/api-keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Netlify Build Hook (required for admin upload rebuild trigger)
# Create at: Netlify Dashboard -> Site settings -> Build & deploy -> Build hooks
NETLIFY_BUILD_HOOK=
